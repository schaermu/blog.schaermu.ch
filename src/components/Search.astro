---
if (!import.meta.env.DEV) {
  await import('@pagefind/component-ui/css');
}
---

{
  !import.meta.env.DEV && (
    <>
      <pagefind-config bundle-path="/pagefind/" />
      <pagefind-modal-trigger class="search-trigger" placeholder="Suche..." />
    </>
  )
}

<script>
  if (!import.meta.env.DEV) {
    import('@pagefind/component-ui');
  }
</script>

<style is:global>
  pagefind-modal-trigger.search-trigger {
    display: block;
    width: 12rem;
  }

  @media (max-width: 768px) {
    pagefind-modal-trigger.search-trigger {
      width: 10rem;
    }
  }

  @media (max-width: 640px) {
    pagefind-modal-trigger.search-trigger {
      width: 8rem;
    }
  }
</style>
