---
const currentYear = new Date().getFullYear();
const footerAttrs = Astro.props;
---

<footer {...footerAttrs} class="w-full border-t border-border mt-auto py-8 text-text-muted">
  <div class="max-w-4xl mx-auto px-4 flex flex-col sm:flex-row justify-between items-center gap-4">
    <p class="text-sm m-0">
      &copy; {currentYear} blog.schaermu.ch
    </p>
    <div class="flex items-center gap-4">
      <a href="/rss.xml" class="text-sm hover:text-accent transition-colors no-underline">
        RSS
      </a>
    </div>
  </div>
</footer>
