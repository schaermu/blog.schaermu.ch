---
/**
 * HeroImage.astro
 *
 * Renders remote hero images via Cloudflare Image Transformations while
 * letting local Astro assets render directly.
 */

import type { ImageMetadata } from 'astro';

interface Props {
  src: string | ImageMetadata;
  alt: string;
  /** Whether this is an above-the-fold image (sets fetchpriority=high + eager loading) */
  priority?: boolean;
  /** CSS class forwarded to the <img> element */
  class?: string;
  /** Optional sizes attribute for contexts narrower than the full article width */
  sizes?: string;
}

const {
  src,
  alt,
  priority = false,
  class: className,
  sizes: customSizes,
} = Astro.props;

const CF_BASE = 'https://blog.schaermu.ch/cdn-cgi/image';
const FALLBACK_WIDTH = 1440;
const FALLBACK_HEIGHT = 810;
const widths = [480, 768, 1024, 1440];

function isRemoteUrl(value: string): boolean {
  return /^https?:\/\//.test(value);
}

/**
 * Build a Cloudflare transformation URL.
 * format=auto lets CF serve AVIF to modern browsers, WebP to older ones,
 * JPEG as fallback — based on the Accept header. No manual <source> tags needed.
 */
function cfUrl(source: string, width: number, quality = 80): string {
  const params = `width=${width},quality=${quality},format=auto,fit=cover`;
  return `${CF_BASE}/${params}/${source}`;
}

const isRemoteSource = typeof src === 'string' && isRemoteUrl(src);

const srcset = isRemoteSource
  ? widths.map((w) => `${cfUrl(src, w)} ${w}w`).join(', ')
  : undefined;

// sizes: matches a typical blog layout with a max-width container
const sizes =
  customSizes ??
  ['(min-width: 1200px) 1024px', '(min-width: 768px) 100vw', '100vw'].join(
    ', ',
  );

const defaultSrc = isRemoteSource
  ? cfUrl(src, FALLBACK_WIDTH)
  : typeof src === 'string'
    ? src
    : src.src;

const width = typeof src === 'string' ? FALLBACK_WIDTH : src.width;
const height = typeof src === 'string' ? FALLBACK_HEIGHT : src.height;
---

<img
  src={defaultSrc}
  srcset={srcset}
  sizes={srcset ? sizes : undefined}
  alt={alt}
  width={width}
  height={height}
  loading={priority ? 'eager' : 'lazy'}
  decoding={priority ? 'sync' : 'async'}
  fetchpriority={priority ? 'high' : 'auto'}
  class={className}
/>
