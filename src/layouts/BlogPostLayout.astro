---
import type { ImageMetadata } from 'astro';
import BaseLayout from './BaseLayout.astro';
import HeroImage from '../components/HeroImage.astro';
import SeriesBadge from '../components/SeriesBadge.astro';
import SeriesNav from '../components/SeriesNav.astro';
import SeriesTopNav from '../components/SeriesTopNav.astro';
import ShareButtons from '../components/ShareButtons.astro';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  heroImage?: string | ImageMetadata;
  tags: string[];
  readingTime: number;
  id: string;
  seriesInfo?: {
    name: string;
    current: number;
    total: number;
    prev?: { title: string; id: string };
    next?: { title: string; id: string };
  };
}

const {
  title,
  description,
  pubDate,
  updatedDate,
  heroImage,
  tags,
  readingTime,
  id,
  seriesInfo,
} = Astro.props;
---

<BaseLayout
  title={title}
  description={description}
  image={heroImage}
  ogType="article"
  flushTop={!!heroImage}
>
  {
    heroImage && (
      <div class="full-bleed mb-8 overflow-hidden">
        <HeroImage
          src={heroImage}
          alt={title}
          priority
          data-pagefind-meta="image[src]"
          class="w-full h-auto max-h-100 object-cover"
          transition:name={`post-hero-${id}`}
        />
      </div>
    )
  }
  <article class="max-w-4xl mx-auto" transition:animate="slide">
    {
      seriesInfo && (
        <SeriesTopNav
          name={seriesInfo.name}
          current={seriesInfo.current}
          total={seriesInfo.total}
          prev={seriesInfo.prev}
          next={seriesInfo.next}
        />
      )
    }

    <header class="mb-10 text-center md:text-left">
      <h1
        class="text-4xl md:text-5xl text-text mb-4 leading-tight"
        transition:name={`post-title-${id}`}
      >
        {title}
      </h1>

      <div
        class="flex flex-wrap items-center justify-center md:justify-start gap-x-4 gap-y-2 text-text-muted text-sm mb-6"
      >
        <time datetime={pubDate.toISOString()}>
          {
            pubDate.toLocaleDateString('de-CH', {
              year: 'numeric',
              month: 'long',
              day: 'numeric',
            })
          }
        </time>

        {
          updatedDate && (
            <>
              <span>&bull;</span>
              <span class="italic">
                Aktualisiert:{' '}
                <time datetime={updatedDate.toISOString()}>
                  {updatedDate.toLocaleDateString('de-CH', {
                    year: 'numeric',
                    month: 'long',
                    day: 'numeric',
                  })}
                </time>
              </span>
            </>
          )
        }

        <span>&bull;</span>
        <span>{readingTime} Min. Lesezeit</span>
      </div>

      {
        seriesInfo && (
          <SeriesBadge
            name={seriesInfo.name}
            current={seriesInfo.current}
            total={seriesInfo.total}
          />
        )
      }

      {
        tags && tags.length > 0 && (
          <div class="flex flex-wrap items-center justify-center md:justify-start gap-2">
            {tags.map((tag) => (
              <a
                href={`/tags/${tag}/`}
                data-pagefind-filter="tag"
                class="text-sm font-medium px-3 py-1 bg-(--color-bg-subtle) text-accent hover:bg-(--color-accent-subtle) rounded-sm transition-colors"
              >
                #{tag}
              </a>
            ))}
          </div>
        )
      }
    </header>

    <div
      class="prose dark:prose-invert max-w-none prose-a:text-accent hover:prose-a:text-accent-hover prose-img:rounded-md prose-headings:text-text"
    >
      <slot />
    </div>

    <ShareButtons
      title={title}
      url={new URL(`/blog/${id}/`, Astro.site).href}
    />

    {
      seriesInfo && (
        <SeriesNav
          name={seriesInfo.name}
          current={seriesInfo.current}
          total={seriesInfo.total}
          prev={seriesInfo.prev}
          next={seriesInfo.next}
        />
      )
    }
  </article>
</BaseLayout>
