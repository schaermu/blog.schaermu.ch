---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const posts = await getCollection('blog', ({ data }) => {
  return process.env.INCLUDE_TEST_FIXTURES === 'true' ? true : !data.testFixture;
});
const tags = [...new Set(posts.flatMap((post) => post.data.tags ?? []))].sort((a, b) => a.localeCompare(b));
---

<BaseLayout title="Tags" description="Browse posts by tag">
  <h1 class="text-3xl text-[var(--color-text)] mb-8">Tags</h1>
  
  <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4">
    {tags.map((tag) => (
      <a 
        href={`/tags/${tag}/`}
        class="flex flex-col justify-between p-6 bg-[var(--color-surface)] border border-[var(--color-border)] rounded-[var(--radius-lg)] hover:shadow-md transition-shadow hover:border-[var(--color-accent)]"
      >
        <span class="text-lg font-bold text-[var(--color-accent)] mb-2">#{tag}</span>
      </a>
    ))}
  </div>
</BaseLayout>
