---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  const tags = [...new Set(posts.flatMap(p => p.data.tags || []))];
  
  return tags.map(tag => ({
    params: { tag },
    props: {
      posts: posts
        .filter(p => p.data.tags && p.data.tags.includes(tag))
        .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()),
      tag,
    },
  }));
}

const { posts, tag } = Astro.props;
---

<BaseLayout title={`Posts tagged "${tag}"`} description={`All posts tagged with ${tag}`}>
  <h1 class="text-3xl font-bold text-[var(--color-text)] mb-8">
    Posts tagged with <span class="text-[var(--color-accent)]">#{tag}</span>
  </h1>
  
  <div class="grid gap-8">
    {posts.map((post) => (
      <article class="flex flex-col bg-[var(--color-surface)] border border-[var(--color-border)] rounded-[var(--radius-lg)] p-6 shadow-sm hover:shadow-md transition-shadow">
        <h2 class="text-2xl font-bold mb-2">
          <a href={`/blog/${post.id}/`} class="text-[var(--color-text)] hover:text-[var(--color-accent)] transition-colors">
            {post.data.title}
          </a>
        </h2>
        
        <div class="flex flex-wrap gap-x-4 gap-y-2 text-sm text-[var(--color-text-muted)] mb-4">
          <time datetime={post.data.pubDate.toISOString()}>
            {post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
          </time>
        </div>
        
        <p class="text-[var(--color-text)] mb-4 flex-grow">
          {post.data.description}
        </p>
        
        {post.data.tags && post.data.tags.length > 0 && (
          <div class="flex flex-wrap gap-2 mt-auto">
            {post.data.tags.map((t: string) => (
              <a 
                href={`/tags/${t}/`}
                class={`text-xs font-medium px-2.5 py-1 rounded-[var(--radius-sm)] transition-colors ${
                  t === tag 
                    ? 'bg-[var(--color-accent)] text-[var(--color-bg)]' 
                    : 'bg-[var(--color-bg-subtle)] text-[var(--color-accent)] hover:bg-[var(--color-accent-subtle)]'
                }`}
              >
                #{t}
              </a>
            ))}
          </div>
        )}
      </article>
    ))}
  </div>
</BaseLayout>
