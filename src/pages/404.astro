---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Seite nicht gefunden"
  description="Die gesuchte Seite existiert nicht"
>
  <div class="flex flex-col items-center justify-center py-20 text-center">
    <h1 class="text-9xl text-accent mb-4 tracking-tighter shadow-sm">404</h1>
    <h2 class="text-3xl mb-6">Seite nicht gefunden</h2>
    <p class="text-xl text-text-muted mb-10 max-w-md mx-auto">
      Ups! Die gesuchte Seite wurde möglicherweise entfernt, umbenannt oder ist
      vorübergehend nicht verfügbar.
    </p>
    <a
      href="/"
      class="inline-flex items-center justify-center px-6 py-3 rounded-lg bg-accent text-surface hover:bg-accent-hover transition-colors font-medium text-lg"
    >
      <span class="mr-2">&larr;</span> Zurück zur Startseite
    </a>
  </div>
</BaseLayout>
