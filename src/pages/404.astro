---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout 
  title="Page Not Found" 
  description="The page you're looking for doesn't exist"
>
  <div class="flex flex-col items-center justify-center py-20 text-center">
    <h1 class="text-9xl text-accent mb-4 tracking-tighter shadow-sm">404</h1>
    <h2 class="text-3xl mb-6">Page Not Found</h2>
    <p class="text-xl text-text-muted mb-10 max-w-md mx-auto">
      Oops! The page you're looking for might have been removed, had its name changed, or is temporarily unavailable.
    </p>
    <a 
      href="/" 
      class="inline-flex items-center justify-center px-6 py-3 rounded-lg bg-accent text-surface hover:bg-accent-hover transition-colors font-medium text-lg"
    >
      <span class="mr-2">&larr;</span> Back to home
    </a>
  </div>
</BaseLayout>
