---
import { getCollection } from 'astro:content';
import HeroImage from '../components/HeroImage.astro';
import BaseLayout from '../layouts/BaseLayout.astro';

const posts = (
  await getCollection('blog', ({ data }) => {
    return process.env.INCLUDE_TEST_FIXTURES === 'true'
      ? true
      : !data.testFixture;
  })
).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout
  title="Blog"
  description="Ein Blog über Software-Entwicklung und Technologie"
>
  <h1 class="text-5xl text-text mb-8">Neueste Beiträge</h1>

  <div class="grid gap-8">
    {
      posts.map((post) => (
        <article class="flex flex-col md:flex-row gap-6 bg-surface border border-border rounded-lg p-6 shadow-sm hover:shadow-md transition-shadow">
          {post.data.heroImage && (
            <div class="w-full md:w-1/3 shrink-0">
              <a
                href={`/blog/${post.id}/`}
                class="block overflow-hidden rounded-md h-full"
              >
                <HeroImage
                  src={post.data.heroImage}
                  alt={post.data.title}
                  sizes="(min-width: 768px) 33vw, 100vw"
                  class="w-full h-full object-cover hover:scale-105 transition-transform duration-300"
                  transition:name={`post-hero-${post.id}`}
                />
              </a>
            </div>
          )}

          <div class="grow flex flex-col justify-center">
            <h2 class="text-3xl mb-2" transition:name={`post-title-${post.id}`}>
              <a
                href={`/blog/${post.id}/`}
                class="text-text hover:text-accent transition-colors"
              >
                {post.data.title}
              </a>
            </h2>

            <div class="flex flex-wrap gap-x-4 gap-y-2 text-sm text-text-muted mb-4">
              <time datetime={post.data.pubDate.toISOString()}>
                {post.data.pubDate.toLocaleDateString('de-CH', {
                  year: 'numeric',
                  month: 'long',
                  day: 'numeric',
                })}
              </time>
              <span>&bull;</span>
              <span>
                {Math.max(
                  1,
                  Math.ceil((post.body?.split(/\s+/).length ?? 0) / 200),
                )}{' '}
                Min. Lesezeit
              </span>
            </div>

            <p class="text-text mb-4 grow line-clamp-3">
              {post.data.description}
            </p>

            {post.data.tags && post.data.tags.length > 0 && (
              <div class="flex flex-wrap gap-2 mt-auto">
                {post.data.tags.map((tag: string) => (
                  <a
                    href={`/tags/${tag}/`}
                    class="text-xs font-medium px-2.5 py-1 bg-(--color-bg-subtle) text-accent hover:bg-(--color-accent-subtle) rounded-sm transition-colors"
                  >
                    #{tag}
                  </a>
                ))}
              </div>
            )}
          </div>
        </article>
      ))
    }
  </div>
</BaseLayout>
