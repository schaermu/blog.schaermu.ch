    "@tailwindcss/vite": "^4.2.2",
    "astro": "^6.1.5",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@playwright/test": "^1.59.1",
    "lefthook": "^2.1.6",
    "pagefind": "^1.5.2",
    "prettier": "^3.8.3",
